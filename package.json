{
  "name": "palpath",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "data:generate": "node dataFormatter/generateBreedingData.mjs",
    "data:passives": "node dataFormatter/generatePassives.mjs",
    "data:save-aliases": "node dataFormatter/generateSaveAliases.mjs",
    "dev": "vite",
    "build": "vite build && tsc -p tsconfig.json",
    "build:pages": "vite build --mode github-pages && tsc -p tsconfig.json",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
